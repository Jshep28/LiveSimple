
* { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --coral: #ff6b5b;
  --coral-dark: #e85444;
  --coral-light: #fce5cd;
  --navy: #004562;
  --dark: #2a252e;
  --mid: #7a7480;
  --light: #f7f4f0;
  --white: #ffffff;
  --border: #ede8e2;
  --green: #3dbf82;
  --red: #e85444;
  --blue: #4a90d9;
}

html {
  height: 100%;
  overflow: hidden;
}

body {
  font-family: 'Lora', Georgia, serif;
  background: var(--light);
  color: var(--dark);
  height: 100%;
  overflow-y: auto;
  overscroll-behavior: none;
}

/* Scrollbar always on top */
::-webkit-scrollbar {
  width: 6px;
  z-index: 9999;
}
::-webkit-scrollbar-track {
  background: transparent;
}
::-webkit-scrollbar-thumb {
  background: rgba(0,0,0,0.18);
  border-radius: 3px;
}
[data-theme="dark"] ::-webkit-scrollbar-thumb {
  background: rgba(255,255,255,0.18);
}

/* Prevent cards/tables from creating stacking context over the scrollbar */
.left-card, .stat-box, .card, .section-card, .port-table, .table-wrap {
  isolation: auto;
  transform: none;
}

/* NAV */
nav {
  background: var(--navy);
  padding: 0 20px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 200;
}

#app-budget .logo {
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 17px;
  color: white;
  letter-spacing: -0.3px;
}
#app-budget .logo em { color: var(--coral); font-style: normal; }

.nav-tabs {
  display: flex;
  gap: 4px;
}
.nav-tab {
  background: none;
  border: none;
  padding: 6px 14px;
  border-radius: 20px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 12px;
  color: rgba(255,255,255,0.75);
  cursor: pointer;
  transition: all 0.2s;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  white-space: nowrap;
}
.nav-tab.active {
  background: rgba(255,255,255,0.2);
  color: white;
}
.nav-tab:hover {
  background: rgba(255,255,255,0.12);
  color: white;
}

/* currency-select replaced with dropdown picker */

/* PAGES */
.page { display: none; }
.page.active { display: block; }

/* HERO BANNER */
.hero {
  background: var(--coral);
  padding: 16px 20px;
  color: white;
  min-height: 80px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.hero-month {
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 28px;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: white;
  line-height: 1.1;
}
.hero-sub {
  font-size: 11px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.65);
  margin-top: 4px;
}

/* LEFT AMOUNT CARD */
.left-card {
  background: white;
  margin: 16px 16px 0;
  border-radius: 16px;
  padding: 20px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  text-align: center;
  position: relative;
  overflow: hidden;
}
.left-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4px;
  background: var(--coral);
}
.left-label {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--mid);
  margin-bottom: 6px;
}
.left-amount {
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 44px;
  letter-spacing: -1px;
  line-height: 1;
}
.left-amount.positive { color: var(--green); }
.left-amount.negative { color: var(--red); }
.left-amount.zero { color: var(--mid); }

/* STATS GRID */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  padding: 16px;
}
.stat-box {
  background: white;
  border-radius: 12px;
  padding: 14px;
  box-shadow: 0 1px 6px rgba(0,0,0,0.05);
}
.stat-box-label {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--mid);
  margin-bottom: 4px;
}
.stat-box-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-top: 2px;
}
.stat-box-type {
  font-size: 11px;
  color: var(--mid);
}
.stat-box-val {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 13px;
  color: var(--dark);
}
.stat-box-val.green { color: var(--green); }
.stat-box-val.red { color: var(--red); }

/* SECTION */
.section {
  margin: 0 16px 16px;
  background: white;
  border-radius: 14px;
  box-shadow: 0 1px 6px rgba(0,0,0,0.05);
  overflow: hidden;
}
.section-head {
  background: var(--navy);
  padding: 10px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.section-head h2 {
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: white;
}
.section-head button {
  background: rgba(255,255,255,0.2);
  border: none;
  border-radius: 20px;
  padding: 3px 10px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 10px;
  color: white;
  cursor: pointer;
  transition: background 0.15s;
}
.section-head button:hover { background: rgba(255,255,255,0.32); }

/* Budget app uses coral section headers */
#app-budget .section-head { background: var(--coral); }

/* TABLE ROWS */
.tracker-row {
  display: grid;
  grid-template-columns: 1fr 90px 90px;
  padding: 10px 16px;
  border-bottom: 1px solid var(--border);
  align-items: center;
  gap: 8px;
}
.tracker-row:last-child { border-bottom: none; }
.tracker-row.header {
  background: var(--light);
  padding: 6px 16px;
}
.tracker-row.header span {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--mid);
  text-align: right;
}
.tracker-row.header span:first-child { text-align: left; }

.row-name {
  font-size: 13px;
  color: var(--dark);
  display: flex;
  align-items: center;
  gap: 6px;
}
.row-name input[type=text] {
  border: none;
  background: none;
  font-family: 'Lora', serif;
  font-size: 13px;
  color: var(--dark);
  width: 100%;
  padding: 0;
  outline: none;
}
.row-name input[type=text]:focus {
  border-bottom: 1px dashed var(--coral);
}
.paid-checkbox {
  width: 16px;
  height: 16px;
  border-radius: 4px;
  accent-color: var(--coral);
  cursor: pointer;
  flex-shrink: 0;
}

.amount-input {
  display: flex;
  align-items: center;
  gap: 2px;
  justify-content: flex-end;
}
.amount-input span {
  font-size: 11px;
  color: var(--mid);
  font-family: 'Montserrat', sans-serif;
}
.amount-input input {
  border: none;
  background: var(--light);
  border-radius: 6px;
  padding: 4px 6px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 13px;
  color: var(--dark);
  width: 70px;
  text-align: right;
  outline: none;
}
.amount-input input:focus {
  background: var(--coral-light);
}

.row-total {
  text-align: right;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 13px;
  color: var(--dark);
}

.section-footer {
  display: grid;
  grid-template-columns: 1fr 90px 90px;
  padding: 10px 16px;
  background: var(--dark);
  gap: 8px;
}
.section-footer span {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 11px;
  color: white;
  text-align: right;
}
.section-footer span:first-child { text-align: left; }

/* EXPENSE TRACKER */
.expense-form {
  padding: 14px 16px;
  display: grid;
  grid-template-columns: 80px 1fr 1fr;
  gap: 8px;
  border-bottom: 1px solid var(--border);
  background: #fffdf9;
}
.expense-form input, .expense-form select {
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 7px 10px;
  font-family: 'Lora', serif;
  font-size: 13px;
  color: var(--dark);
  background: white;
  outline: none;
  width: 100%;
}
.expense-form input:focus, .expense-form select:focus {
  border-color: var(--coral);
}
.expense-form-row2 {
  padding: 0 16px 12px;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 8px;
  background: #fffdf9;
  border-bottom: 1px solid var(--border);
}
.expense-form-row2 input {
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 7px 10px;
  font-family: 'Lora', serif;
  font-size: 13px;
  color: var(--dark);
  background: white;
  outline: none;
  width: 100%;
}
.expense-form-row2 input:focus { border-color: var(--coral); }
.add-expense-btn {
  background: var(--coral);
  border: none;
  border-radius: 8px;
  padding: 7px 16px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 12px;
  color: white;
  cursor: pointer;
  white-space: nowrap;
}
.add-expense-btn:hover { background: var(--coral-dark); }

.expense-row {
  display: grid;
  grid-template-columns: 70px 80px 1fr auto;
  padding: 9px 16px;
  border-bottom: 1px solid var(--border);
  align-items: center;
  gap: 8px;
  font-size: 13px;
}
.expense-row:last-child { border-bottom: none; }
.expense-date { color: var(--mid); font-size: 11px; }
.expense-amount {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 13px;
  color: var(--red);
}
.expense-cat {
  background: var(--coral-light);
  color: var(--coral-dark);
  border-radius: 20px;
  padding: 2px 8px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 10px;
  display: inline-block;
}
.expense-note { color: var(--mid); font-size: 12px; }
.delete-btn {
  background: none;
  border: none;
  color: #b0b8c4;
  cursor: pointer;
  font-size: 15px;
  padding: 2px 6px;
  line-height: 1;
  border-radius: 4px;
  transition: color 0.15s, background 0.15s;
}
.delete-btn:hover { color: var(--red); background: rgba(232,84,68,0.08); }

/* BREAKDOWN */
.breakdown-bar-row {
  padding: 8px 16px;
  border-bottom: 1px solid var(--border);
}
.breakdown-bar-row:last-child { border-bottom: none; }
.breakdown-label-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 5px;
}
.breakdown-cat { font-size: 13px; color: var(--dark); }
.breakdown-pct {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 12px;
  color: var(--mid);
}
.breakdown-bar-bg {
  height: 6px;
  background: var(--border);
  border-radius: 3px;
  overflow: hidden;
}
.breakdown-bar-fill {
  height: 100%;
  background: var(--coral);
  border-radius: 3px;
  transition: width 0.4s ease;
}

/* MONTH SELECTOR (budget page) */
.month-selector {
  display: flex;
  gap: 8px;
  padding: 16px;
  overflow-x: auto;
  scrollbar-width: none;
}
.month-selector::-webkit-scrollbar { display: none; }
.month-btn {
  flex-shrink: 0;
  background: white;
  border: 1.5px solid var(--border);
  border-radius: 20px;
  padding: 5px 14px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 11px;
  color: var(--mid);
  cursor: pointer;
  transition: all 0.2s;
}
.month-btn.active {
  background: var(--coral);
  border-color: var(--coral);
  color: white;
}

/* HABIT TRACKER PAGE */
.habit-hero {
  background: var(--coral);
  padding: 16px 20px;
  min-height: 80px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.habit-hero h1 {
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 28px;
  letter-spacing: 5px;
  color: white;
  line-height: 1.1;
}
.habit-hero p {
  font-size: 11px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.65);
  margin-top: 4px;
}

.habit-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  padding: 16px;
}
.habit-stat {
  background: white;
  border-radius: 12px;
  padding: 12px 10px;
  text-align: center;
  box-shadow: 0 1px 6px rgba(0,0,0,0.05);
}
.habit-stat-val {
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 24px;
  color: var(--coral);
  line-height: 1;
}
.habit-stat-label {
  font-size: 10px;
  color: var(--mid);
  margin-top: 3px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

/* DAILY HABITS */
.daily-habits-section {
  margin: 0 16px 16px;
  background: white;
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 1px 6px rgba(0,0,0,0.05);
}

.habit-add-row {
  padding: 10px 16px;
  display: flex;
  gap: 8px;
  border-bottom: 1px solid var(--border);
  background: #fffdf9;
}
.habit-add-row input {
  flex: 1;
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 7px 12px;
  font-family: 'Lora', serif;
  font-size: 13px;
  color: var(--dark);
  outline: none;
  background: white;
}
.habit-add-row input:focus { border-color: var(--coral); }
.habit-add-row button {
  background: var(--coral);
  border: none;
  border-radius: 8px;
  padding: 7px 14px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 12px;
  color: white;
  cursor: pointer;
}

/* CALENDAR GRID */
.cal-wrap {
  overflow-x: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}
.cal-table {
  min-width: max-content;
}
.cal-header {
  display: flex;
  background: var(--light);
  border-bottom: 1px solid var(--border);
}
.cal-habit-col {
  width: 160px;
  flex-shrink: 0;
  padding: 8px 12px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--mid);
  border-right: 1px solid var(--border);
  position: sticky;
  left: 0;
  z-index: 3;
  background: var(--light);
}
.cal-day-head {
  width: 34px;
  flex-shrink: 0;
  text-align: center;
  padding: 4px 2px;
}
.cal-day-num {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 12px;
  color: var(--dark);
  display: block;
  line-height: 1.3;
}
.cal-day-name {
  font-family: 'Montserrat', sans-serif;
  font-weight: 600;
  font-size: 8px;
  color: var(--mid);
  text-transform: uppercase;
  display: block;
}
.cal-day-head.today .cal-day-num {
  background: var(--coral);
  color: white;
  border-radius: 50%;
  width: 22px;
  height: 22px;
  line-height: 22px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.cal-row {
  display: flex;
  border-bottom: 1px solid var(--border);
}
.cal-row:last-child { border-bottom: none; }
.cal-row:hover { background: #fafaf9; }
.cal-row:hover .cal-habit-name { background: #fafaf9; }

.cal-habit-name {
  width: 160px;
  flex-shrink: 0;
  padding: 10px 12px;
  font-size: 12px;
  color: var(--dark);
  border-right: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 4px;
  position: sticky;
  left: 0;
  z-index: 2;
  background: white;
}
.cal-habit-name .pct {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 10px;
  color: var(--coral);
  flex-shrink: 0;
}
.cal-habit-name .del {
  background: none;
  border: none;
  cursor: pointer;
  color: #b0b8c4;
  font-size: 12px;
  padding: 0;
  line-height: 1;
  flex-shrink: 0;
  display: none;
  transition: color 0.15s;
}
.cal-row:hover .cal-habit-name .del { display: block; }
.cal-habit-name .del:hover { color: var(--red); }

.cal-cell {
  width: 34px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 40px;
  cursor: pointer;
  transition: background 0.1s;
}
.cal-cell:hover { background: var(--coral-light); }
.cal-cell.checked { background: var(--coral); }
.cal-cell.checked::after {
  content: '✓';
  font-size: 14px;
  font-weight: 700;
  color: white;
}
.cal-cell.future { opacity: 0.3; cursor: default; }
.cal-cell.future:hover { background: none; }

/* WEEKLY / MONTHLY HABITS */
.wm-section {
  margin: 0 16px 16px;
  background: white;
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 1px 6px rgba(0,0,0,0.05);
}
.wm-row {
  display: flex;
  align-items: center;
  padding: 10px 16px;
  border-bottom: 1px solid var(--border);
  gap: 12px;
}
.wm-row:last-child { border-bottom: none; }
.wm-row input[type=checkbox] {
  width: 18px;
  height: 18px;
  border-radius: 4px;
  accent-color: var(--coral);
  cursor: pointer;
  flex-shrink: 0;
}
.wm-row-name {
  font-size: 13px;
  flex: 1;
}
.wm-row-name input {
  border: none;
  background: none;
  font-family: 'Lora', serif;
  font-size: 13px;
  color: var(--dark);
  width: 100%;
  outline: none;
}
.wm-row-name input:focus { border-bottom: 1px dashed var(--coral); }
.wm-del {
  background: none;
  border: none;
  cursor: pointer;
  color: #b0b8c4;
  font-size: 14px;
  display: none;
  transition: color 0.15s;
}
.wm-row:hover .wm-del { display: block; }
.wm-del:hover { color: var(--red); }

.wm-add {
  display: flex;
  gap: 8px;
  padding: 10px 16px;
  border-top: 1px solid var(--border);
  background: #fffdf9;
}
.wm-add input {
  flex: 1;
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 6px 10px;
  font-family: 'Lora', serif;
  font-size: 13px;
  outline: none;
}
.wm-add input:focus { border-color: var(--coral); }
.wm-add button {
  background: var(--coral);
  border: none;
  border-radius: 8px;
  padding: 6px 14px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 11px;
  color: white;
  cursor: pointer;
}

/* WEEK TABS */
.week-tabs {
  display: flex;
  gap: 6px;
  padding: 12px 16px 0;
  background: var(--light);
}
.week-tab {
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: 20px;
  padding: 4px 12px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 11px;
  color: var(--mid);
  cursor: pointer;
  transition: all 0.2s;
}
.week-tab.active {
  background: var(--coral);
  border-color: var(--coral);
  color: white;
}

/* RECURRING TOGGLE BUTTON */
.recurring-btn {
  flex-shrink: 0;
  background: none;
  border: 1px solid var(--border);
  border-radius: 4px;
  font-size: 11px;
  color: var(--mid);
  cursor: pointer;
  padding: 1px 4px;
  line-height: 1.4;
  transition: all 0.15s;
}
.recurring-btn:hover { border-color: var(--coral); color: var(--coral); }
.recurring-btn.active { background: var(--coral); border-color: var(--coral); color: white; }

/* SPENDING INSIGHTS BAR */
.insights-bar {
  margin: 0 16px 10px;
  background: #fff5f0;
  border: 1px solid #fcd5c8;
  border-radius: 12px;
  padding: 10px 14px;
  display: none;
  flex-direction: column;
  gap: 5px;
}
.insights-bar.visible { display: flex; }
.insight-item {
  display: flex;
  align-items: center;
  gap: 7px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 600;
  font-size: 11px;
  color: var(--coral-dark);
}

/* MONTH NOTES */
.month-notes-wrap {
  margin: 0 16px 16px;
}
.month-notes-wrap textarea {
  width: 100%;
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 10px 12px;
  font-family: 'Lora', serif;
  font-size: 13px;
  color: var(--dark);
  background: white;
  resize: none;
  outline: none;
  min-height: 64px;
  line-height: 1.5;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}
.month-notes-wrap textarea:focus { border-color: var(--coral); }
.month-notes-label {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--mid);
  margin-bottom: 5px;
}

/* ROLLOVER BADGE on left-card */
.rollover-badge {
  font-family: 'Montserrat', sans-serif;
  font-weight: 600;
  font-size: 11px;
  color: var(--mid);
  margin-top: 4px;
}
.rollover-badge span { font-weight: 700; }
.rollover-badge span.pos { color: var(--green); }
.rollover-badge span.neg { color: var(--red); }

/* WEEKLY HABIT COMPLETION */
.week-tab-rate {
  font-size: 9px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  opacity: 0.7;
  margin-left: 3px;
}

/* COPY BAR — helper strip shown when month has no data */
.copy-bar {
  display: none;
  background: #fff8f0;
  border-bottom: 1px solid var(--border);
  padding: 9px 16px;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}
.copy-bar.visible { display: flex; }

/* TRACKER ROW DELETE BUTTON */
.tracker-row { position: relative; }
.row-del {
  position: absolute;
  right: -4px;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  color: #b0b8c4;
  font-size: 15px;
  cursor: pointer;
  padding: 4px 6px;
  line-height: 1;
  opacity: 0;
  transition: opacity 0.15s, color 0.15s;
  z-index: 2;
}
.tracker-row:hover .row-del { opacity: 1; }
.row-del:hover { color: var(--red); }

/* MINI PROGRESS BAR under each tracker row */
.row-progress {
  height: 2px;
  background: var(--border);
  border-radius: 1px;
  margin: 0 16px 0;
  overflow: hidden;
}
.row-progress-fill {
  height: 100%;
  border-radius: 1px;
  transition: width 0.3s ease;
}

/* ── REALISED RETURNS CARD ───────────────────────────────────── */
.realised-card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
}
.realised-card-cell {
  padding: 14px 16px;
  text-align: center;
  border-right: 1px solid var(--border);
}
.realised-card-cell:last-child { border-right: none; }
.realised-card-full {
  grid-column: 1 / -1;
  border-right: none;
  border-bottom: 1px solid var(--border);
}
.realised-card-label {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--mid);
  margin-bottom: 5px;
}
.realised-card-val {
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 20px;
  line-height: 1;
  word-break: break-all;
}
.realised-card-sub {
  font-size: 10px;
  color: var(--mid);
  margin-top: 3px;
}
[data-theme="dark"] .realised-card-cell { border-color: #1e2d3d; }
[data-theme="dark"] .realised-card-full { border-color: #1e2d3d; }

/* Goal yearly table needs separate borders so border-radius works on tds */
.goal-yearly-table { border-collapse: collapse; }

/* ── HOLDING ACTION BUTTONS ──────────────────────────────────── */
.holding-actions { display:flex; gap:4px; align-items:center; flex-wrap:nowrap; }
.act-btn {
  font-family:'Montserrat',sans-serif; font-weight:700; font-size:9px;
  border:none; border-radius:5px; padding:3px 7px; cursor:pointer;
  white-space:nowrap; transition:opacity 0.15s;
}
.act-btn:hover { opacity:0.75; }
.act-btn.add  { background:rgba(0,69,98,0.12); color:var(--navy); }
.act-btn.sell { background:rgba(239,68,68,0.12); color:var(--red); }
.act-btn.div  { background:rgba(34,197,94,0.12); color:var(--green); }
.act-btn.del  { background:rgba(239,68,68,0.08); color:#9ca3af; }

/* ── MONTHLY HEATMAP ─────────────────────────────────────────── */
.month-heatmap { display:flex; flex-direction:column; gap:6px; }
.heatmap-year-row { display:flex; align-items:center; gap:4px; flex-wrap:nowrap; }
.heatmap-year-label { font-family:'Montserrat',sans-serif; font-weight:700; font-size:10px; color:var(--mid); width:36px; flex-shrink:0; }
.heatmap-cell {
  width:44px; height:36px; border-radius:6px; flex-shrink:0;
  display:flex; align-items:center; justify-content:center;
  font-family:'Montserrat',sans-serif; font-weight:700; font-size:9px;
  color:white; cursor:default; transition:transform 0.1s;
}
.heatmap-cell:hover { transform:scale(1.08); }
.heatmap-cell.empty { background:var(--border); color:var(--mid); }
.heatmap-month-labels { display:flex; gap:4px; padding-left:40px; margin-bottom:4px; }
.heatmap-month-label { width:44px; text-align:center; font-family:'Montserrat',sans-serif; font-weight:700; font-size:9px; color:var(--mid); flex-shrink:0; }

/* ── TARGET ALLOCATION DRIFT ─────────────────────────────────── */
.alloc-drift-row { display:flex; align-items:center; gap:10px; margin-bottom:10px; flex-wrap:wrap; }
.alloc-drift-label { font-family:'Montserrat',sans-serif; font-weight:700; font-size:11px; color:var(--dark); width:90px; flex-shrink:0; }
.alloc-drift-bar-wrap { flex:1; min-width:100px; height:8px; background:var(--border); border-radius:4px; position:relative; }
.alloc-drift-bar-actual { height:100%; border-radius:4px; transition:width 0.4s; }
.alloc-drift-target-line { position:absolute; top:-4px; bottom:-4px; width:2px; background:var(--dark); border-radius:1px; }
[data-theme="dark"] .alloc-drift-target-line { background: #e0e8f0; }
.alloc-drift-pcts { font-family:'Montserrat',sans-serif; font-weight:700; font-size:10px; white-space:nowrap; }
.alloc-target-input { width:52px; border:1px solid var(--border); border-radius:6px; padding:5px 6px; font-family:'Montserrat',sans-serif; font-weight:700; font-size:12px; text-align:center; outline:none; }
.alloc-target-input:focus { border-color:var(--navy); }

/* ── INVEST ACTION DRAWERS ───────────────────────────────────── */
.invest-drawer-overlay { display:none; position:fixed; inset:0; background:rgba(26,35,50,0.55); z-index:500; align-items:flex-end; justify-content:center; }
.invest-drawer-overlay.open { display:flex; }
.invest-drawer { background:white; border-radius:20px 20px 0 0; width:100%; max-width:480px; padding:0 0 32px; transform:translateY(100%); transition:transform 0.3s cubic-bezier(0.32,0,0.15,1); box-shadow:0 -4px 32px rgba(0,0,0,0.18); }
.invest-drawer-overlay.open .invest-drawer { transform:translateY(0); }
.invest-drawer-title { font-family:'Montserrat',sans-serif; font-weight:900; font-size:16px; color:var(--dark); }
.invest-drawer-body { padding:16px 20px 0; }
.invest-drawer-field { margin-bottom:12px; }
.invest-drawer-field label { display:block; font-family:'Montserrat',sans-serif; font-weight:700; font-size:10px; text-transform:uppercase; letter-spacing:1px; color:var(--mid); margin-bottom:5px; }
.invest-drawer-input { width:100%; border:1.5px solid var(--border); border-radius:10px; padding:10px 12px; font-family:'Lora',serif; font-size:15px; color:var(--dark); background:var(--light); outline:none; }
.invest-drawer-input:focus { border-color:var(--navy); background:white; }
.invest-drawer-submit { margin-top:14px; width:100%; background:var(--navy); border:none; border-radius:12px; padding:13px; font-family:'Montserrat',sans-serif; font-weight:700; font-size:14px; color:white; cursor:pointer; }
.invest-drawer-submit:hover { background:var(--navy-light); }

/* ── GOAL ACHIEVE CARD ───────────────────────────────────────── */
.goal-achieve-card-inner {
  background: #e8eef2;
  border: 2px solid #004562;
  border-radius: 10px;
  padding: 14px 16px;
  margin-top: 12px;
}
.goal-achieve-label {
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 13px;
  color: #004562;
  margin-bottom: 10px;
}
.goal-achieve-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}
.goal-achieve-stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.goal-achieve-stat-label {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--mid);
}
.goal-achieve-stat-val {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 13px;
}
@media (max-width: 480px) {
  .goal-achieve-stats {
    grid-template-columns: 1fr 1fr;
  }
}

/* ── INVEST APP COMPREHENSIVE MOBILE ────────────────────────────
   Targets the invest panel, tables, grids at small viewports     */
@media (max-width: 600px) {
  /* Panel */
  #app-invest .panel {
    padding: 10px 8px 60px;
  }

  /* Hero cards — single column */
  .hero-grid {
    grid-template-columns: 1fr !important;
    gap: 8px;
  }
  .hero-card.full { grid-column: 1 !important; }
  .hero-val.lg { font-size: 26px; }
  .hero-val { font-size: 20px; }

  /* Section */
  #app-invest .section { border-radius: 10px; }

  /* Holdings add form */
  .add-form {
    grid-template-columns: 1fr 1fr !important;
    gap: 8px;
  }
  .add-form .form-group:first-child { grid-column: 1 / -1; }
  .add-btn { grid-column: 1 / -1; }

  /* All port-tables: allow horizontal scroll, don't overflow page */
  .port-table th, .port-table td {
    padding: 8px 8px;
    font-size: 11px;
    white-space: nowrap;
  }

  /* Allocation row: stack chart above legend */
  .alloc-wrap-row {
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 12px;
  }

  /* Breakdown grid: single column */
  .breakdown-grid {
    grid-template-columns: 1fr !important;
  }
  .breakdown-col + .breakdown-col {
    border-left: none !important;
    border-top: 1px solid var(--border);
  }

  /* Calculator */
  .calc-grid {
    grid-template-columns: 1fr !important;
    padding: 12px;
  }
  .calc-input-group.half { grid-column: auto; }
  .calc-result-grid {
    grid-template-columns: 1fr 1fr !important;
    padding: 0 12px 12px;
  }
  .calc-result-val { font-size: 14px; }

  /* Goal grid */
  .goal-grid {
    grid-template-columns: 1fr !important;
    padding: 12px;
  }

  /* Performance legend */
  .perf-legend {
    gap: 10px;
    padding: 0 12px 8px;
  }

  /* Invest settings */
  #tab-invest-settings .settings-section { margin: 8px; }
  #tab-invest-settings .settings-row { flex-wrap: wrap; gap: 6px; }
}


/* EMPTY STATE */
.empty {
  padding: 30px 20px;
  text-align: center;
  color: var(--mid);
  font-size: 13px;
  font-style: italic;
}

/* YEAR SELECTOR */
.year-bar {
  background: var(--navy);
  padding: 10px 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
}
.year-bar button {
  background: none;
  border: none;
  color: white;
  font-size: 20px;
  cursor: pointer;
  opacity: 0.6;
  line-height: 1;
  padding: 0 4px;
  transition: opacity 0.2s;
}
.year-bar button:hover { opacity: 1; }
.year-label {
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 16px;
  color: white;
  letter-spacing: 3px;
}
.settings-section-title {
  background: var(--navy);
  padding: 10px 16px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 900;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: white;
}
.settings-section {
  margin: 16px;
  background: white;
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 1px 6px rgba(0,0,0,0.05);
}
.settings-row {
  padding: 14px 16px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}
.settings-row:last-child { border-bottom: none; }
.settings-row-info { flex: 1; }
.settings-row-label {
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 13px;
  color: var(--dark);
  margin-bottom: 2px;
}
.settings-row-desc { font-size: 12px; color: var(--mid); }
.settings-btn {
  border: none;
  border-radius: 8px;
  padding: 7px 14px;
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  font-size: 11px;
  cursor: pointer;
  white-space: nowrap;
  transition: opacity 0.2s;
}
.settings-btn:hover { opacity: 0.8; }
.settings-btn.primary { background: var(--coral); color: white; }
.settings-btn.danger { background: #fee2e2; color: var(--red); }
.settings-btn.neutral { background: var(--light); color: var(--dark); border: 1px solid var(--border); }
.year-cards { padding: 16px; display: flex; flex-direction: column; gap: 10px; }
.year-card {
  background: white;
  border-radius: 12px;
  border: 1px solid var(--border);
  padding: 14px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}
.year-card-info { flex: 1; }
.year-card-year { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 18px; color: var(--dark); }
.year-card-meta { font-size: 12px; color: var(--mid); margin-top: 2px; }
.year-card-actions { display: flex; gap: 6px; }
.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(42,37,46,0.6);
  z-index: 1000;
  align-items: center;
  justify-content: center;
  padding: 20px;
}
.modal-overlay.open { display: flex; }
.modal {
  background: white;
  border-radius: 16px;
  padding: 24px;
  max-width: 340px;
  width: 100%;
}
.modal-title { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 16px; color: var(--dark); margin-bottom: 8px; }
.modal-body { font-size: 13px; color: var(--mid); line-height: 1.6; margin-bottom: 20px; }
.modal-actions { display: flex; gap: 8px; justify-content: flex-end; }
.modal-btn { border: none; border-radius: 8px; padding: 9px 18px; font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 12px; cursor: pointer; }
.modal-btn.cancel { background: var(--light); color: var(--mid); }
.modal-btn.confirm { background: var(--red); color: white; }
.review-hero { background: var(--coral); padding: 16px 20px; min-height: 80px; display: flex; flex-direction: column; justify-content: center; }
.review-hero h1 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 26px; letter-spacing: 4px; color: white; }
.review-hero p { font-size: 11px; font-family: 'Montserrat', sans-serif; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.65); margin-top: 4px; }
.review-big-stat { background: white; margin: 16px 16px 0; border-radius: 16px; padding: 20px; text-align: center; }
.review-big-label { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 10px; text-transform: uppercase; letter-spacing: 2px; color: var(--mid); margin-bottom: 6px; }
.review-big-num { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 42px; letter-spacing: -1px; line-height: 1; color: var(--coral); }
.review-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 16px; }
.review-card { background: white; border-radius: 12px; padding: 14px; box-shadow: 0 1px 6px rgba(0,0,0,0.05); text-align: center; }
.review-card-val { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 22px; color: var(--dark); line-height: 1; }
.review-card-val.green { color: var(--green); }
.review-card-val.red { color: var(--red); }
.review-card-label { font-size: 11px; color: var(--mid); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.5px; font-family: 'Montserrat', sans-serif; font-weight: 700; }
.review-month-bars { padding: 0 16px 16px; }
.rmb-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
.rmb-label { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 10px; color: var(--mid); width: 30px; flex-shrink: 0; }
.rmb-bar-wrap { flex: 1; height: 18px; background: var(--light); border-radius: 4px; overflow: hidden; }
.rmb-fill-income { background: var(--green); height: 100%; border-radius: 4px; }
.rmb-fill-expense { background: var(--coral); height: 100%; border-radius: 4px; }
.rmb-val { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 10px; color: var(--mid); min-width: 50px; text-align: right; flex-shrink: 0; }

